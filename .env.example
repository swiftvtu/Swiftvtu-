# ── App ──────────────────────────────────────
APP_NAME=SwiftVTU
APP_ENV=development          # development | production
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440   # 24 hours
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── MongoDB ──────────────────────────────────
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=swiftvtu

# ── Paystack ─────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_WEBHOOK_SECRET=your-paystack-webhook-secret

# ── Flutterwave ──────────────────────────────
FLW_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
FLW_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
FLW_WEBHOOK_SECRET=your-flutterwave-webhook-secret

# ── VTpass ───────────────────────────────────
VTPASS_API_KEY=your-vtpass-api-key
VTPASS_PUBLIC_KEY=your-vtpass-public-key
VTPASS_SECRET_KEY=your-vtpass-secret-key
VTPASS_BASE_URL=https://sandbox.vtpass.com/api   # Use https://vtpass.com/api in production

# ── CORS ─────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5500

# ── Email ────────────────────────────────────────────
EMAIL_PROVIDER=sendgrid              # sendgrid | smtp
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@swiftvtu.com
EMAIL_FROM_NAME=SwiftVTU

# SMTP fallback (only if EMAIL_PROVIDER=smtp)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_USE_TLS=true

# App URLs (used in email links)
FRONTEND_URL=http://localhost:5500
SUPPORT_EMAIL=support@swiftvtu.com
